{
  "name": "@independo/inderun-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "generate": "node contracts/scripts/generate-contracts.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,mjs,js}\"",
    "format:check": "prettier --check \"**/*.{ts,mjs,js}\"",
    "upgrade": "corepack prepare pnpm@latest --activate && pnpm --recursive update"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "quicktype": "^23.3.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
