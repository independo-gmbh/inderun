{
  "name": "@independo/inderun-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm test:js && pnpm test:rust && pnpm test:kotlin && pnpm test:swift",
    "test:js": "pnpm -r test",
    "test:rust": "cargo test --workspace",
    "test:kotlin": "cd android && ./gradlew test",
    "test:swift": "swift test",
    "generate": "pnpm generate:code && pnpm generate:kotlin",
    "generate:code": "node contracts/scripts/generate-contracts.mjs",
    "generate:kotlin": "cd android && ./gradlew :inderun-contracts:spotlessApply",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "pnpm format:js && pnpm format:rust && pnpm format:kotlin && pnpm format:swift",
    "format:js": "prettier --write \"**/*.{ts,mjs,js}\"",
    "format:rust": "cargo fmt --all",
    "format:kotlin": "cd android && ./gradlew spotlessApply",
    "format:swift": "cd ios/IndeRun && swiftlint --fix",
    "format:check": "pnpm format:check:js && pnpm format:check:rust && pnpm format:check:kotlin && pnpm format:check:swift",
    "format:check:js": "prettier --check \"**/*.{ts,mjs,js}\"",
    "format:check:rust": "cargo fmt --all -- --check",
    "format:check:kotlin": "cd android && ./gradlew spotlessCheck",
    "format:check:swift": "cd ios/IndeRun && swiftlint lint --strict",
    "upgrade": "corepack prepare pnpm@latest --activate && pnpm --recursive update"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@saithodev/semantic-release-backmerge": "^4.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.0.3",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "quicktype": "^23.3.21",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
