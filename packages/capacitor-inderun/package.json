{
  "name": "@independo/capacitor-inderun",
  "version": "0.1.0",
  "description": "Thin Capacitor bridge for IndeRun across web, iOS, and Android.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "android",
    "ios",
    "Package.swift",
    "IndeRunCapacitor.podspec",
    "README.md"
