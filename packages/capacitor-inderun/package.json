      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/core": "^8.0.0",
    "@independo/inderun-contracts": "workspace:^",
    "@independo/inderun-web": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  }
}
