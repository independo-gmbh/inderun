{
  "name": "@independo/inderun-route-core-wasm",
  "version": "0.1.2",
  "description": "WASM wrapper package for the IndeRun Rust route-planning core.",
  "license": "MIT",
  "author": {
    "name": "Independo GmbH",
    "url": "https://www.independo.app"
  },
  "homepage": "https://github.com/independo-gmbh/inderun#readme",
  "bugs": "https://github.com/independo-gmbh/inderun/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/independo-gmbh/inderun.git",
    "directory": "packages/inderun-route-core-wasm"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "inderun",
    "ai",
    "routing",
    "wasm",
    "route-planning"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "generated",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm build && node test/smoke.mjs",
    "prepublishOnly": "pnpm run build && node -e \"process.exit(require('fs').existsSync('generated/inderun_route_core_bg.wasm')?0:(console.error('Missing generated WASM bindings — build the Rust core with wasm-bindgen before publishing (see the Generate section in README.md).'),1))\""
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
