{
  "name": "@independo/inderun-demo-proxy",
  "private": true,
  "version": "0.1.0",
  "description": "Standalone OpenAI-compatible proxy backend for IndeRun demo apps.",
  "type": "module",
  "main": "./dist/index.js",
