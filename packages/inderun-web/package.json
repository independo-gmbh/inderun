{
  "name": "@independo/inderun-web",
  "version": "0.1.1-dev.1",
  "description": "TypeScript/Web SDK for IndeRun.",
  "license": "MIT",
  "author": {
    "name": "Independo GmbH",
    "url": "https://www.independo.app"
  },
  "homepage": "https://github.com/independo-gmbh/inderun#readme",
  "bugs": "https://github.com/independo-gmbh/inderun/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/independo-gmbh/inderun.git",
    "directory": "packages/inderun-web"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "inderun",
    "ai",
    "sdk",
    "web",
    "llm",
    "routing"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "default": "./dist/openai.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@independo/inderun-contracts": "workspace:^",
    "@independo/inderun-route-core-wasm": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
