{
  "name": "@independo/inderun-contracts",
  "version": "0.1.1-dev.1",
  "description": "Canonical JSON Schemas, generated TypeScript types, and validators for IndeRun contracts.",
  "license": "MIT",
  "author": {
    "name": "Independo GmbH",
    "url": "https://www.independo.app"
  },
  "homepage": "https://github.com/independo-gmbh/inderun#readme",
  "bugs": "https://github.com/independo-gmbh/inderun/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/independo-gmbh/inderun.git",
    "directory": "packages/contracts"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "inderun",
    "ai",
    "contracts",
    "json-schema",
    "validation"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "vitest": "^3.2.6"
  }
}
